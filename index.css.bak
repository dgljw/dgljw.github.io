.bgrgba>img{
    position:fixed;
}
video {
    position: fixed;
    z-index: -99;
}/*背景*/
    
.bgrgba {
    background-color: rgba(128,128,128,0.3);
}

.edge {
    height: 6px;
    background-color: #ffffff;
    width: 100%;
    align: 'right';
}

.edge2 {
    height: 2px;
    color: #ccc;
    width: 100%;
    align: 'right';
}

.toptxt {
    color: skyblue;
}

.toptxt>a {
    color: pink;
}

.sl {
    color: skyblue;
}

.pinglun {
    vspace: 30;
}
source {
    min-height: 100%;
    min-width: 100%;
    height: 100%;
    width: 100%;
}
img{
border-radius: 16px;
}
article{
opacity:0.9;
}